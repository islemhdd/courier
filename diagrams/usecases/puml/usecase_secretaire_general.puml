@startuml usecase_secretaire_generale
left to right direction
skinparam shadowing false

' --- Acteurs ---

actor "Secrétaire Générale" as SG
actor "Chef Général" as ChefGen

' Positionnement approximatif
SG -[hidden]-> ChefGen

' --- Système ---

rectangle "Système de Gestion de Courrier" {

    usecase "Authentification" as Auth

    usecase "Ajouter un nouveau\ncourrier reçu pour\nl'établissement" as AjouterCourrier

    usecase "Demander la validation\ndu Chef Général" as DemandeValidationCG

    usecase "Valider le courrier\nreçu" as ValiderCourrier

    usecase "Consulter tous les\ncourriers de l'établissement" as ConsulterTous
}

' --- Relations acteur principal ---

SG --> AjouterCourrier
SG --> ConsulterTous

' --- Relations include ---

AjouterCourrier ..> Auth : <<include>>
ConsulterTous ..> Auth : <<include>>

AjouterCourrier ..> DemandeValidationCG : <<include>>
DemandeValidationCG ..> ValiderCourrier : <<include>>

' --- Acteur secondaire ---

ChefGen --> ValiderCourrier

@enduml
