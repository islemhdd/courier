@startuml usecase_secretaire
left to right direction
skinparam shadowing false

' --- Acteurs ---

actor "Secrétaire d'Organe" as SecOrg
actor "Chef d'Organe" as ChefOrg

' Positionnement approximatif


' --- Système ---

rectangle "Système de Gestion de Courrier" {

    usecase "Authentification" as Auth

    usecase "Consulter les courriers\nreçus par l'organe" as Consulter

    usecase "Répondre au courrier\ndédié à l'organe" as Repondre

    usecase "Demander la validation\nde la réponse" as DemandeValidation

    usecase "Valider la réponse\nau courrier" as ValiderReponse
}

' --- Relations acteur principal ---

SecOrg --> Consulter
SecOrg --> Repondre

' --- Relations include ---

Consulter ..> Auth : <<include>>
Repondre ..> Auth : <<include>>
Repondre ..> DemandeValidation : <<include>>
DemandeValidation ..> ValiderReponse : <<include>>

' --- Acteur secondaire ---

ChefOrg --> ValiderReponse

@enduml
